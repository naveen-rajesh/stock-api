# Optional proxy support for YouTube transcript fetching.
# YouTube often blocks transcript requests from hosting-provider IPs.
YOUTUBE_PROXY_URL=http://username:password@host:port
YOUTUBE_HTTP_PROXY=http://username:password@host:port
YOUTUBE_HTTPS_PROXY=http://username:password@host:port

# Optional: require requests to come through RapidAPI.
RAPIDAPI_PROXY_SECRET=your-rapidapi-proxy-secret-here

# Optional: Database (default is in-memory mock).
DATABASE_URL=sqlite+aiosqlite:///./studyapi.db

# Server
PORT=8080
ENV=development
