# Copy to .env and fill in values

# Summary provider: local avoids external AI limits.
SUMMARY_PROVIDER=local

# Optional: Gemini summaries instead of local summaries.
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# Optional: require requests to come through RapidAPI.
RAPIDAPI_PROXY_SECRET=your-rapidapi-proxy-secret-here

# Optional: Database (default is in-memory mock)
DATABASE_URL=sqlite+aiosqlite:///./studyapi.db

# Server
PORT=8000
ENV=development
